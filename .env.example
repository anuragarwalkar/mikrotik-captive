# ─────────────────────────────────────────────────────────────────────────────
# MikroTik Captive Portal – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# Enable "Google Identity" API, create an OAuth 2.0 Web Client ID.
# Add your captive portal domain to "Authorised JavaScript origins".
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── Redis ─────────────────────────────────────────────────────────────────────
# Point to your Redis server (can be the same host as this server)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to "true" if using TLS (e.g. Redis Cloud, Upstash)
REDIS_TLS=false

# ── MikroTik RouterOS REST API ────────────────────────────────────────────────
# Base URL of your MikroTik router (RouterOS v7+ required for REST API)
# Leave blank to run without a real router (dev/testing mode)
MIKROTIK_API_URL=http://192.168.88.1
MIKROTIK_API_USER=admin
MIKROTIK_API_PASS=
# Name of the hotspot profile to assign new users
MIKROTIK_HOTSPOT_PROFILE=default
# How long each session is valid (MikroTik uptime-limit format)
HOTSPOT_SESSION_LIMIT=8h
# Set to "true" only if your router has a valid SSL cert
MIKROTIK_VERIFY_SSL=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Secret header value required to call /api/admin/* endpoints
ADMIN_SECRET=change-this-to-a-strong-random-secret
# CORS allowed origin (use your captive portal URL in production)
ALLOWED_ORIGIN=*
